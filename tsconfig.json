{
	"extends": "@tsconfig/svelte/tsconfig.json",

	"compilerOptions": {
		"types": ["svelte", "node", "obsidian-typings"],
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
		"allowJs": true,
		"noImplicitAny": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
    "lib": ["DOM", "ES2022"]
	},
	"include": ["**/*.ts", "**/*.svelte"]
}
